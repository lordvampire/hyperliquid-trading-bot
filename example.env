# Hyperliquid Trading Bot Configuration
# Copy this to .env and fill in your values

# Hyperliquid — use testnet first!
HL_SECRET_KEY=0x_your_testnet_private_key_here
HL_TESTNET=true
HL_WALLET_ADDRESS=0x_your_wallet_address_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Risk Management
RISK_MAX_DAILY_DD_PCT=5.0
RISK_MAX_CONSECUTIVE_LOSSES=3
RISK_DEFAULT_SIZE_PCT=2.0

# Server
HOST=0.0.0.0
PORT=8000
